# Copy to `.env.local` for development. Required for JWT sign/verify (SRS 2.4).
# Use at least 32 random characters in production.
JWT_SECRET=change-me-use-at-least-32-characters-roms

# MySQL 8.x for Prisma (`orders`, `order_items`). Omit to use in-memory store only.
# Use the same URL in .env.local when running `node server.mjs` so U6 PATCH hits the DB that received POST /api/orders.
# Special characters in the password must be URL-encoded.
#
# If Prisma logs: Unknown authentication plugin `sha256_password` — Node's driver does not support that plugin.
# Fix in MySQL (Workbench or CLI), then restart `npm run dev`:
#   ALTER USER 'YOUR_USER'@'localhost' IDENTIFIED WITH mysql_native_password BY 'YOUR_PASSWORD';
#   FLUSH PRIVILEGES;
# (Or use caching_sha2_password + allowPublicKeyRetrieval for local dev, see URL below.)
#
# For local MySQL 8 with caching_sha2_password, this URL often works:
# DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/roms?allowPublicKeyRetrieval=true"
#
# Passwords like Sanjita123 need no URL-encoding. Encode only special characters in the
# userinfo part (e.g. @ → %40, # → %23, / → %2F) if your password contains them.

# Use `npm run dev` (runs server.mjs) so Socket.io attaches to the HTTP server.
# Plain `next dev` will not expose Socket.io; POST /api/orders still works but
# `new_order` will not broadcast until the custom server is used.

# Optional: if the browser hits a different host/port than the Socket.io server
# (default is window.location.origin, e.g. http://localhost:3000).
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Optional SRS U5 — shared kitchen display secret (wall KDS). When set:
# - Browser must send the same value as header X-ROMS-Kitchen-Token on PATCH /api/orders/:orderId/status
#   (NEXT_PUBLIC_ROMS_KITCHEN_TOKEN below), unless staff use kitchen JWT cookie/Bearer instead.
# - Socket.io join_kitchen must send this string as the first argument.
# ROMS_KITCHEN_TOKEN=dev-shared-kitchen-secret
# NEXT_PUBLIC_ROMS_KITCHEN_TOKEN=dev-shared-kitchen-secret
